# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME= it464-Test02-Docker-Container-2-jirayu.nimv

MY_USERNAME= jirayu.nimv #ใส่ชื่อผู้ใช้ของคุณ
# พอร์ตที่ใช้สำหรับบริการต่าง ๆ
HTTP_PORT=10401
# พอร์ตสำหรับ Web Proxy (Nginx)
PMA_PORT=10402
# พอร์ตสำหรับ phpMyAdmin

# DB Details
DB_NAME=db-storage
DB_USER=root